{
  "manifest_version": 3,
  "name": "Is the Price Polished?",
  "version": "0.3.9",
  "description": "Porównywarka cen PLN względem EUR na Steam",
  "icons": {
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://polishourprices.pl/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://store.steampowered.com/app/*"],
      "css": ["styles/main.css"],
      "js": ["content/prefetch.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://store.steampowered.com/app/*"],
      "js": [
        "assets/icons.js",
        "core/utils.js",
        "ui/builder.js",
        "content/main.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/flags/*.svg"
      ],
      "matches": ["https://store.steampowered.com/*"]
    }
  ]
}
