{
  "manifest_version": 3,
  "name": "Is the Price Polished?",
  "version": "1.2.1",
  "description": "Sprawdź, czy cena gry na Steam jest uczciwa!",
  "icons": {
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://store.steampowered.com/*",
    "https://api.polishourprices.pl/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://store.steampowered.com/app/*"],
      "css": ["styles/main.css"],
      "js": ["scripts/prefetch.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://store.steampowered.com/app/*"],
      "js": [
        "scripts/icons.js",
        "scripts/utils.js",
        "scripts/builder.js",
        "scripts/main.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "scripts/background.js",
    "scripts": ["scripts/background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "extension@polishourprices.pl",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
