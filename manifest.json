{
  "manifest_version": 3,
  "name": "Is the Price Polished?",
  "version": "1.1.3",
  "description": "Sprawdź, czy cena gry na Steam jest uczciwa!",
  "icons": {
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://store.steampowered.com/*",
    "https://api.polishourprices.pl/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://store.steampowered.com/app/*"],
      "css": ["styles/main.css"],
      "js": ["scripts/prefetch.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://store.steampowered.com/app/*"],
      "js": [
        "scripts/icons.js",
        "scripts/utils.js",
        "scripts/builder.js",
        "scripts/main.js"
      ],
      "run_at": "document_end"
    }
  ]
}
